<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primary"
        android:paddingTop="32dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="20dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FruitShop"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hoa quả tươi ngon mỗi ngày"
            android:textSize="13sp"
            android:textColor="#B3FFFFFF"
            android:paddingTop="4dp" />

    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardElevation="3dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trạng thái"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:textAllCaps="true"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vui lòng đăng nhập để mua hàng"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp">

        <Button
            android:id="@+id/btnProducts"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="10dp"
            android:text="Xem Danh Sách Hoa Quả"
            android:textSize="14sp"
            android:backgroundTint="@color/primary" />

        <Button
            android:id="@+id/btnCategories"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="10dp"
            android:text="Xem Danh Mục Hoa Quả"
            android:textSize="14sp"
            android:backgroundTint="@color/secondary" />

        <Button
            android:id="@+id/btnCart"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="10dp"
            android:text="Hóa Đơn Hiện Tại"
            android:textSize="14sp"
            android:backgroundTint="@color/accent"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="10dp"
            android:text="Đăng Nhập"
            android:textSize="14sp"
            android:backgroundTint="@color/green" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Đăng Xuất"
            android:textSize="14sp"
            android:backgroundTint="@color/red"
            android:visibility="gone" />

        <!-- Spacer -->
        <View android:layout_width="match_parent" android:layout_height="16dp" />

    </LinearLayout>

</LinearLayout>
